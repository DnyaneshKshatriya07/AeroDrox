@model IEnumerable<AeroDroxUAV.Models.Order>
@{
    ViewData["Title"] = "Order History";
    var orderList = Model?.ToList() ?? new List<AeroDroxUAV.Models.Order>();
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0"><i class="fas fa-history me-2"></i>My Orders</h1>
            <p class="text-muted">Track and manage your orders</p>
        </div>
        <a href="/Drone/Index" class="btn btn-primary">
            <i class="fas fa-drone me-2"></i>Shop More
        </a>
    </div>

    @if (!orderList.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-box-open fa-5x text-muted mb-3"></i>
            <h3>No Orders Yet</h3>
            <p class="text-muted mb-4">Looks like you haven't placed any orders yet.</p>
            <a href="/Drone/Index" class="btn btn-success btn-lg">
                <i class="fas fa-drone me-2"></i>Start Shopping
            </a>
        </div>
    }
    else
    {
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <h5 class="card-title">Total Orders</h5>
                        <h2>@ViewBag.TotalOrders</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <h5 class="card-title">Total Spent</h5>
                        <h2>₹@ViewBag.TotalSpent.ToString("N2")</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <h5 class="card-title">Pending Orders</h5>
                        <h2>@ViewBag.PendingOrders</h2>
                    </div>
                </div>
            </div>
        </div>

        @foreach (var order in orderList)
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-light">
                    <div class="row align-items-center">
                        <div class="col-md-3">
                            <span class="text-muted">Order #:</span>
                            <span class="fw-bold">AERO-@order.Id</span>
                        </div>
                        <div class="col-md-3">
                            <span class="text-muted">Placed on:</span>
                            <span>@order.OrderDate.ToString("dd MMM yyyy")</span>
                        </div>
                        <div class="col-md-2">
                            <span class="text-muted">Total:</span>
                            <span class="fw-bold text-success">₹@order.TotalAmount.ToString("N2")</span>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex justify-content-between align-items-center">
                                @if (order.OrderStatus == "Delivered")
                                {
                                    <span class="badge bg-success fs-6 p-2">@order.OrderStatus</span>
                                }
                                else if (order.OrderStatus == "Cancelled")
                                {
                                    <span class="badge bg-danger fs-6 p-2">@order.OrderStatus</span>
                                }
                                else if (order.OrderStatus == "Shipped")
                                {
                                    <span class="badge bg-info fs-6 p-2">@order.OrderStatus</span>
                                }
                                else if (order.OrderStatus == "Confirmed")
                                {
                                    <span class="badge bg-primary fs-6 p-2">@order.OrderStatus</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark fs-6 p-2">@order.OrderStatus</span>
                                }
                                <a href="/Checkout/OrderDetails/@order.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye"></i> View Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        @{
                            var items = order.OrderItems?.ToList() ?? new List<OrderItem>();
                        }
                        @foreach (var item in items.Take(3))
                        {
                            <div class="col-md-4 mb-2 mb-md-0">
                                <div class="d-flex align-items-center">
                                    <div class="me-2">
                                        @if (item.ProductType == "Drone")
                                        {
                                            <i class="fas fa-drone fa-lg text-primary"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-tools fa-lg text-success"></i>
                                        }
                                    </div>
                                    <div>
                                        <span class="fw-bold">@item.ProductName</span><br>
                                        <small class="text-muted">Qty: @item.Quantity x ₹@item.DiscountPrice.ToString("N2")</small>
                                    </div>
                                </div>
                            </div>
                        }
                        @if (items.Count() > 3)
                        {
                            <div class="col-md-12 mt-2">
                                <small class="text-muted">+ @(items.Count() - 3) more item(s)</small>
                            </div>
                        }
                    </div>
                </div>
                @if (order.OrderStatus == "Pending" || order.OrderStatus == "Confirmed")
                {
                    <div class="card-footer bg-white">
                        <form asp-action="CancelOrder" asp-controller="Checkout" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@order.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger" 
                                    onclick="return confirm('Are you sure you want to cancel this order?')">
                                <i class="fas fa-times me-1"></i>Cancel Order
                            </button>
                        </form>
                    </div>
                }
            </div>
        }
    }
</div>
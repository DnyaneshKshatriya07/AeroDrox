@model AeroDroxUAV.Models.PaymentViewModel
@{
    ViewData["Title"] = "Checkout";
    var cartItems = ViewBag.CartItems as IEnumerable<AeroDroxUAV.Models.CartItem> ?? new List<AeroDroxUAV.Models.CartItem>();
    var cartTotal = Model.TotalAmount;
}

<div class="container py-4">
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-credit-card me-2"></i>Checkout</h4>
                </div>
                <div class="card-body">
                    <!-- Progress Steps -->
                    <div class="checkout-steps mb-4">
                        <div class="row text-center">
                            <div class="col-4">
                                <div class="step completed">
                                    <div class="step-icon bg-success text-white">
                                        <i class="fas fa-shopping-cart"></i>
                                    </div>
                                    <span class="step-text">Cart</span>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="step active">
                                    <div class="step-icon bg-primary text-white">
                                        <i class="fas fa-credit-card"></i>
                                    </div>
                                    <span class="step-text">Payment</span>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="step">
                                    <div class="step-icon bg-secondary text-white">
                                        <i class="fas fa-check"></i>
                                    </div>
                                    <span class="step-text">Confirmation</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <form asp-action="ProcessPayment" method="post" id="paymentForm" onsubmit="return validateForm()">
                    @Html.AntiForgeryToken()
    
                    <!-- Shipping Information -->
                    <div class="section mb-4">
                        <h5 class="section-title"><i class="fas fa-truck me-2"></i>Shipping Information</h5>
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="ShippingAddress" class="form-label">Address *</label>
                                <textarea asp-for="ShippingAddress" class="form-control" rows="2" required></textarea>
                                <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="ShippingCity" class="form-label">City *</label>
                                <input asp-for="ShippingCity" class="form-control" required>
                                <span asp-validation-for="ShippingCity" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="ShippingState" class="form-label">State *</label>
                                <input asp-for="ShippingState" class="form-control" required>
                                <span asp-validation-for="ShippingState" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="ShippingPinCode" class="form-label">Pin Code *</label>
                                <input asp-for="ShippingPinCode" class="form-control" required pattern="[1-9][0-9]{5}" title="Please enter a valid 6-digit pin code">
                                <span asp-validation-for="ShippingPinCode" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="ShippingPhone" class="form-label">Phone Number *</label>
                                <input asp-for="ShippingPhone" class="form-control" required pattern="[6-9][0-9]{9}" title="Please enter a valid 10-digit mobile number">
                                <span asp-validation-for="ShippingPhone" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

    <!-- Payment Method -->
    <div class="section mb-4">
        <h5 class="section-title"><i class="fas fa-money-bill me-2"></i>Payment Method</h5>
        
        <div class="payment-methods">
            <!-- Credit/Debit Card -->
            <div class="payment-option mb-3">
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="PaymentMethod" id="cardPayment" value="Card" required>
                    <label class="form-check-label" for="cardPayment">
                        <i class="fas fa-credit-card me-2"></i>Credit/Debit Card
                    </label>
                </div>
                <div class="payment-details card-payment" style="display: none;">
                    <div class="row mt-3">
                        <div class="col-md-8 mb-3">
                            <label class="form-label">Card Number</label>
                            <input type="text" name="CardNumber" class="form-control" placeholder="1234 5678 9012 3456" maxlength="16">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">CVV</label>
                            <input type="text" name="Cvv" class="form-control" placeholder="123" maxlength="3">
                        </div>
                        <div class="col-md-8 mb-3">
                            <label class="form-label">Card Holder Name</label>
                            <input type="text" name="CardHolderName" class="form-control" placeholder="John Doe">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Expiry Date</label>
                            <div class="row">
                                <div class="col-6">
                                    <select name="ExpiryMonth" class="form-select">
                                        <option value="">Month</option>
                                        @for (int m = 1; m <= 12; m++)
                                        {
                                            <option value="@m.ToString("00")">@m.ToString("00")</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-6">
                                    <select name="ExpiryYear" class="form-select">
                                        <option value="">Year</option>
                                        @for (int y = DateTime.Now.Year; y <= DateTime.Now.Year + 10; y++)
                                        {
                                            <option value="@y">@y</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- UPI -->
            <div class="payment-option mb-3">
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="PaymentMethod" id="upiPayment" value="UPI">
                    <label class="form-check-label" for="upiPayment">
                        <i class="fas fa-mobile-alt me-2"></i>UPI
                    </label>
                </div>
                <div class="payment-details upi-payment" style="display: none;">
                    <div class="row mt-3">
                        <div class="col-md-8 mb-3">
                            <label class="form-label">UPI ID</label>
                            <input type="text" name="UpiId" class="form-control" placeholder="username@okhdfcbank">
                        </div>
                        <div class="col-md-4 mb-3">
                            <button type="button" class="btn btn-outline-primary verify-upi" style="margin-top: 31px;">
                                <i class="fas fa-check-circle me-1"></i>Verify
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Net Banking -->
            <div class="payment-option mb-3">
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="PaymentMethod" id="netbankingPayment" value="NetBanking">
                    <label class="form-check-label" for="netbankingPayment">
                        <i class="fas fa-university me-2"></i>Net Banking
                    </label>
                </div>
                <div class="payment-details netbanking-payment" style="display: none;">
                    <div class="row mt-3">
                        <div class="col-md-8 mb-3">
                            <label class="form-label">Select Bank</label>
                            <select name="BankName" class="form-select">
                                <option value="">Choose your bank</option>
                                <option value="SBI">State Bank of India</option>
                                <option value="HDFC">HDFC Bank</option>
                                <option value="ICICI">ICICI Bank</option>
                                <option value="Axis">Axis Bank</option>
                                <option value="Kotak">Kotak Mahindra Bank</option>
                                <option value="PNB">Punjab National Bank</option>
                                <option value="BOB">Bank of Baroda</option>
                                <option value="Canara">Canara Bank</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Cash on Delivery -->
            <div class="payment-option mb-3">
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="PaymentMethod" id="codPayment" value="COD">
                    <label class="form-check-label" for="codPayment">
                        <i class="fas fa-money-bill-wave me-2"></i>Cash on Delivery
                    </label>
                </div>
                <div class="payment-details cod-payment" style="display: none;">
                    <div class="alert alert-info mt-3 mb-0">
                        <i class="fas fa-info-circle me-2"></i>
                        Pay with cash when your order is delivered. No online payment required.
                    </div>
                </div>
            </div>
        </div>
        <span asp-validation-for="PaymentMethod" class="text-danger"></span>
    </div>

    <!-- Order Summary for Mobile -->
    <div class="d-block d-lg-none mb-4">
        <div class="card">
            <div class="card-header bg-light">
                <h5 class="mb-0">Order Summary</h5>
            </div>
            <div class="card-body">
                @foreach (var item in cartItems)
                {
                    <div class="d-flex justify-content-between mb-2">
                        <div>
                            <span class="fw-bold">@item.ProductName</span><br>
                            <small class="text-muted">Qty: @item.Quantity</small>
                        </div>
                        <span>₹@((item.ProductPrice * item.Quantity).ToString("N2"))</span>
                    </div>
                }
                <hr>
                <div class="d-flex justify-content-between">
                    <span class="fw-bold">Total:</span>
                    <span class="fw-bold text-primary">₹@cartTotal.ToString("N2")</span>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center">
        <a href="/Cart/Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Cart
        </a>
        <button type="submit" class="btn btn-success btn-lg" id="payNowBtn">
            <i class="fas fa-lock me-2"></i>Place Order ₹@cartTotal.ToString("N2")
        </button>
    </div>
</form>
                </div>
            </div>
        </div>

        <!-- Order Summary - Desktop -->
        <div class="col-lg-4 d-none d-lg-block">
            <div class="card shadow-sm sticky-top" style="top: 100px;">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Order Summary</h5>
                </div>
                <div class="card-body">
                    @foreach (var item in cartItems)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="d-flex align-items-center">
                                @if (!string.IsNullOrEmpty(item.ProductImage))
                                {
                                    <img src="@item.ProductImage" alt="@item.ProductName" style="width: 50px; height: 50px; object-fit: cover;" class="rounded me-2">
                                }
                                else
                                {
                                    <img src="https://images.unsplash.com/photo-1473968512647-3e447244af8f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" 
                                         style="width: 50px; height: 50px; object-fit: cover;" class="rounded me-2">
                                }
                                <div>
                                    <span class="fw-bold">@item.ProductName</span><br>
                                    <small class="text-muted">Qty: @item.Quantity x ₹@item.ProductPrice.ToString("N2")</small>
                                </div>
                            </div>
                            <span class="fw-bold">₹@((item.ProductPrice * item.Quantity).ToString("N2"))</span>
                        </div>
                    }
                    
                    <hr>
                    
                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal</span>
                        <span>₹@cartTotal.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Shipping</span>
                        <span class="text-success">Free</span>
                    </div>
                    
                    <hr>
                    
                    <div class="d-flex justify-content-between mb-3">
                        <span class="fw-bold h5">Total</span>
                        <span class="fw-bold text-primary h5">₹@cartTotal.ToString("N2")</span>
                    </div>

                    <div class="alert alert-success mb-0">
                        <i class="fas fa-shield-alt me-2"></i>
                        Your information is secure. All transactions are encrypted.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .checkout-steps .step {
        position: relative;
        padding: 0 10px;
    }
    
    .checkout-steps .step-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 10px;
        transition: all 0.3s ease;
    }
    
    .checkout-steps .step.completed .step-icon {
        background: #28a745 !important;
    }
    
    .checkout-steps .step.active .step-icon {
        transform: scale(1.1);
        box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.2);
    }
    
    .checkout-steps .step.active .step-text {
        font-weight: bold;
        color: #0d6efd;
    }
    
    .section-title {
        color: #333;
        border-bottom: 2px solid #0d6efd;
        padding-bottom: 10px;
        margin-bottom: 20px;
    }
    
    .payment-option {
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 15px;
        transition: all 0.3s ease;
        cursor: pointer;
    }
    
    .payment-option:hover {
        border-color: #0d6efd;
        background: #f8f9fa;
    }
    
    .payment-option.selected {
        border-color: #0d6efd;
        background: #f0f7ff;
    }
    
    .payment-details {
        padding: 15px 0 0;
        margin-top: 15px;
        border-top: 1px solid #dee2e6;
    }
    
    .sticky-top {
        top: 100px;
    }
    
    .btn-success {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        border: none;
        padding: 12px 30px;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    
    .btn-success:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3);
    }
    
    .verify-upi {
        transition: all 0.3s ease;
    }
    
    .verify-upi:hover {
        transform: translateY(-2px);
        box-shadow: 0 3px 10px rgba(13, 110, 253, 0.3);
    }
    
    @@media (max-width: 768px) {
        .checkout-steps .step-icon {
            width: 35px;
            height: 35px;
            font-size: 14px;
        }
        
        .section-title {
            font-size: 18px;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        $(document).ready(function() {
            // Payment method toggle
            $('input[name="PaymentMethod"]').change(function() {
                $('.payment-details').hide();
                $('.payment-option').removeClass('selected');
                
                var selectedValue = $(this).val();
                $(this).closest('.payment-option').addClass('selected');
                
                if (selectedValue === 'Card') {
                    $('.card-payment').show();
                } else if (selectedValue === 'UPI') {
                    $('.upi-payment').show();
                } else if (selectedValue === 'NetBanking') {
                    $('.netbanking-payment').show();
                } else if (selectedValue === 'COD') {
                    $('.cod-payment').show();
                }
                
                // Update button text based on payment method
                var buttonText = selectedValue === 'COD' ? 'Place Order (Pay on Delivery)' : 'Place Order & Pay ₹@cartTotal.ToString("N2")';
                $('#payNowBtn').html('<i class="fas fa-lock me-2"></i>' + buttonText);
            });

            // UPI Verify button
            $('.verify-upi').click(function() {
                var upiId = $('input[name="UpiId"]').val();
                if (!upiId) {
                    toastr.warning('Please enter UPI ID');
                    return;
                }
                
                $(this).html('<i class="fas fa-spinner fa-spin me-1"></i>Verifying...').prop('disabled', true);
                
                setTimeout(() => {
                    $(this).html('<i class="fas fa-check-circle me-1"></i>Verified').removeClass('btn-outline-primary').addClass('btn-success');
                    toastr.success('UPI ID verified successfully');
                }, 1500);
            });

            // Form submission with loading state
            $('#paymentForm').submit(function() {
                var paymentMethod = $('input[name="PaymentMethod"]:checked').val();
                
                if (!paymentMethod) {
                    toastr.warning('Please select a payment method');
                    return false;
                }
                
                $('#payNowBtn').html('<i class="fas fa-spinner fa-spin me-2"></i>Processing...').prop('disabled', true);
                return true;
            });

            // Card number formatting
            $('input[name="CardNumber"]').on('input', function() {
                $(this).val($(this).val().replace(/\D/g, '').substring(0, 16));
            });

            // CVV formatting
            $('input[name="Cvv"]').on('input', function() {
                $(this).val($(this).val().replace(/\D/g, '').substring(0, 3));
            });

            // Show/hide payment details based on initial selection
            var initialSelection = $('input[name="PaymentMethod"]:checked').val();
            if (initialSelection) {
                if (initialSelection === 'Card') {
                    $('.card-payment').show();
                } else if (initialSelection === 'UPI') {
                    $('.upi-payment').show();
                } else if (initialSelection === 'NetBanking') {
                    $('.netbanking-payment').show();
                } else if (initialSelection === 'COD') {
                    $('.cod-payment').show();
                }
            }
        });

        function validateForm() {
            var paymentMethod = $('input[name="PaymentMethod"]:checked').val();
            
            if (!paymentMethod) {
                toastr.warning('Please select a payment method');
                return false;
            }
            
            // Validate shipping fields
            var address = $('textarea[name="ShippingAddress"]').val();
            var city = $('input[name="ShippingCity"]').val();
            var state = $('input[name="ShippingState"]').val();
            var pincode = $('input[name="ShippingPinCode"]').val();
            var phone = $('input[name="ShippingPhone"]').val();
            
            if (!address || !city || !state || !pincode || !phone) {
                toastr.warning('Please fill in all shipping information');
                return false;
            }
            
            // Validate pincode format
            var pincodeRegex = /^[1-9][0-9]{5}$/;
            if (!pincodeRegex.test(pincode)) {
                toastr.warning('Please enter a valid 6-digit pin code');
                return false;
            }
            
            // Validate phone format
            var phoneRegex = /^[6-9][0-9]{9}$/;
            if (!phoneRegex.test(phone)) {
                toastr.warning('Please enter a valid 10-digit mobile number');
                return false;
            }
            
            $('#payNowBtn').html('<i class="fas fa-spinner fa-spin me-2"></i>Processing...').prop('disabled', true);
            return true;
        }
    </script>
}